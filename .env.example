# ─────────────────────────────────────────────────────────────────────────────
# Variables de entorno — Amasandería El Sol
# IMPORTANTE: Este archivo es solo una plantilla.
# NUNCA agregues tus llaves reales aquí.
# Configura las variables reales en: Netlify UI → Site settings → Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# Flow.cl — Sandbox
FLOW_API_KEY=tu_api_key_aqui
FLOW_SECRET_KEY=tu_secret_key_aqui
FLOW_BASE_URL=https://sandbox.flow.cl/api

# Cuando pases a producción, cambia FLOW_BASE_URL a:
# FLOW_BASE_URL=https://www.flow.cl/api

# URL pública del sitio en Netlify (sin barra al final)
SITE_URL=https://amasanderia-el-sol.netlify.app
